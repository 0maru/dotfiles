# 読み取り専用の Git / GitHub 操作は自動で許可する。
prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
)
prefix_rule(
    pattern = ["git", "diff"],
    decision = "allow",
)
prefix_rule(
    pattern = ["git", "log"],
    decision = "allow",
)
prefix_rule(
    pattern = ["git", "fetch"],
    decision = "allow",
)
prefix_rule(
    pattern = ["git", "switch", "-c"],
    decision = "allow",
)
prefix_rule(
    pattern = ["git", "add"],
    decision = "allow",
)
prefix_rule(
    pattern = ["gh", "pr", "view"],
    decision = "allow",
)
prefix_rule(
    pattern = ["gh", "pr", "checks"],
    decision = "allow",
)
prefix_rule(
    pattern = ["gh", "run", "view"],
    decision = "allow",
)

# 日常的に AI へ任せる Git 操作は自動で許可する。
prefix_rule(
    pattern = ["git", "commit"],
    decision = "allow",
)
prefix_rule(
    pattern = ["git", "reset"],
    decision = "prompt",
    justification = "履歴を書き換える可能性があるため確認してから行う。",
)
prefix_rule(
    pattern = ["git", "push"],
    decision = "allow",
)

# 外部状態の更新は毎回レビューする。
prefix_rule(
    pattern = ["gh", "pr", "create"],
    decision = "prompt",
    justification = "Pull Request の作成は確認してから行う。",
)
prefix_rule(
    pattern = ["gh", "pr", "edit"],
    decision = "prompt",
    justification = "Pull Request の更新は確認してから行う。",
)
prefix_rule(
    pattern = ["gh", "api"],
    decision = "prompt",
    justification = "GitHub API は read/write の両方があり得るため毎回確認する。",
)

# 破壊的な操作は自動実行させない。
prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "破壊的な履歴操作は手動で実行する。",
)
prefix_rule(
    pattern = ["git", "clean", "-fd"],
    decision = "forbidden",
    justification = "未追跡ファイルの削除は手動で実行する。",
)
prefix_rule(
    pattern = ["git", "push", ["--force", "--force-with-lease", "-f"]],
    decision = "forbidden",
    justification = "強制 push は手動で実行する。",
)
prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "forbidden",
    justification = "再帰削除は手動で実行する。",
)
prefix_rule(pattern=["git", "fetch", "origin"], decision="allow")
prefix_rule(pattern=["/opt/homebrew/bin/mise", "install", "node@24.15.0"], decision="allow")
prefix_rule(pattern=["/opt/homebrew/bin/mise", "exec", "node@24.15.0", "--", "pnpm", "build"], decision="allow")
prefix_rule(pattern=["/Users/0maru/.local/share/mise/installs/flutter/3.35.5-stable/bin/dart", "format"], decision="allow")
prefix_rule(pattern=["/Users/0maru/.local/share/mise/installs/flutter/3.35.5-stable/bin/flutter", "test"], decision="allow")
prefix_rule(pattern=["/Users/0maru/.local/share/mise/installs/flutter/3.35.5-stable/bin/flutter", "analyze"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["git", "switch", "-c"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit", "-m"], decision="allow")
prefix_rule(pattern=["env", "HUSKY=0", "git", "commit", "-m", "Sentryのストレージ不足エラーを確実に除外", "-m", "Sentry の beforeSend からストレージ不足起因のイベント判定を切り出し、exception chain や message からも検出できるようにした。\\n\\nNo space left on device が OSError を先頭に持つイベントでも GitHub issue 化されないようにするため。"], decision="allow")
prefix_rule(pattern=["git", "commit", "--no-verify"], decision="allow")
prefix_rule(pattern=["make", "setupGitHooks"], decision="allow")
